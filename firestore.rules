rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard high-security helper definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Connection test document rule
    match /test/connection {
      allow get: if true;
    }

    // Users collection rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Sub-collection for Career Coach chat messages
      match /chatHistory/{messageId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
